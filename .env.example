# 复制为 .env 后填写（或在管理台「API 设置」保存）
# 完整 Key 禁止写入 config/*.yaml

# --- 全局回退（可选）---
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 按 profile 独立 Key（推荐；与 global.yaml ai.models 的 id 对应）---
# LLM_KEY_SONNET=sk-ant-...
# LLM_KEY_HAIKU=sk-ant-...

# 是否默认启用 LLM 解析 PRD（1=启用，0=规则解析）
USE_LLM_PARSE=0

# --- 项目鉴权（按 config/projects/*.yaml 的 credentials_env / token_env）---
# PROJECT_A_CREDENTIALS_USER=demo
# PROJECT_A_CREDENTIALS_PASS=secret
